<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema aplicado à janela do Android enquanto o processo está a iniciar -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- CORREÇÃO: Força o fundo a ser branco imediatamente, eliminando o ecrã preto -->
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Tema aplicado assim que o Flutter assume o controlo gráfico -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>